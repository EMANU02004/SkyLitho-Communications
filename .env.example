# Copy this file to .env and fill in your values
PORT=3000
NODE_ENV=production

# Admin panel password (plain text — the server hashes it)
ADMIN_PASSWORD=change_me_in_production

# Secret key for JWT signing — generate a long random string
JWT_SECRET=replace_with_a_long_random_secret_string

# Optional: override data directory for machine JSON storage (useful for persistent disk on Render)
# DATA_DIR=/data
